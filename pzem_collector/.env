# ── Serial / Modbus Connection ──
# The USB-to-TTL serial port (usually /dev/ttyUSB0 on Linux)
PZEM_SERIAL_PORT=/dev/ttyUSB0
PZEM_BAUDRATE=9600
PZEM_MODBUS_ADDRESS=1

# ── Device Identity ──
# Unique identifier for this specific PZEM module
PZEM_DEVICE_ID=pzem-extension-cord
# The user ID in EcoHome to which this data belongs
ECOHOME_USER_ID=BaTR5YIQb52GnDPrjw6I0veN1tEx5EDP

# ── API Connection ──
# URL of your EcoHome backend (e.g., http://localhost:5000 or https://api.ecohome.com)
ECOHOME_API_URL=http://localhost:5000
# The same API key configured in the backend's .env.local
DEVICE_API_KEY=c5de99b8c7087d3bf866c61fbaffb0337fd7ff102b38c9591e905ff544f4242d

# ── Collection Settings ──
# How often to poll the sensor (seconds)
PZEM_POLL_INTERVAL=5
# Send readings to the API in batches of N
PZEM_BATCH_SIZE=1
